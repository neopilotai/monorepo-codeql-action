{
  "name": "@babel/monorepo",
  "version": "8.0.0",
  "private": true,
  "description": "Babel monorepo - The compiler for writing next generation JavaScript",
  "license": "MIT",
  "repository": "https://github.com/babel/babel",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "make bootstrap",
    "build": "node ./scripts/build.js --useWorkspaces",
    "build:fast": "node ./scripts/build.js --useWorkspaces --quick",
    "clean": "node ./scripts/build.js --clean",
    "watch": "node ./scripts/build.js --watch",
    "test": "jest",
    "test:ci": "jest --ci --maxWorkers=4",
    "lint": "eslint packages --ext .js",
    "format": "prettier --write packages/**/*.js",
    "publish": "lerna publish",
    "bootstrap": "node ./scripts/bootstrap.js"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.0",
    "@babel/core": "^8.0.0",
    "@babel/preset-env": "^8.0.0",
    "@babel/preset-typescript": "^8.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "chalk": "^5.0.0",
    "enquirer": "^4.0.0",
    "eslint": "^8.0.0",
    "glob": "^10.0.0",
    "jest": "^29.0.0",
    "lerna": "^7.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "typescript": "^5.0.0",
    "yarn": "^1.22.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@1.22.22"
}
