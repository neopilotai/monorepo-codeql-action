                    "category": "Unknown",
                    "severity": "unknown"
                  },
                  {
                    "id": "CWE-96",
                    "name": "Unknown",
                    "category": "Unknown",
                    "severity": "unknown"
                  },
                  {
                    "id": "CWE-97",
                    "name": "Unknown",
                    "category": "Unknown",
                    "severity": "unknown"
                  },
                  {
                    "id": "CWE-98",
