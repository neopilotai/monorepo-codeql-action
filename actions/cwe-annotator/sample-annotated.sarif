{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "version": "2.14.0",
          "informationUri": "https://codeql.github.com/",
          "rules": [
            {
              "id": "js/injection",
              "name": "Code injection",
              "description": "This query checks for code injection vulnerabilities.",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "security",
                  "injection",
                  "cwe:CWE-89",
                  "cwe-name:sql-injection",
                  "cwe-category:injection",
                  "cwe-severity:high",
                  "cwe:CWE-90",
                  "cwe-name:unknown",
                  "cwe-category:unknown",
                  "cwe-severity:unknown",
                  "cwe:CWE-91",
                  "cwe:CWE-93",
                  "cwe:CWE-94",
                  "cwe-name:code-injection",
                  "cwe-severity:critical",
                  "cwe:CWE-95",
                  "cwe:CWE-96",
                  "cwe:CWE-97",
                  "cwe:CWE-98",
                  "cwe:CWE-99"
                ],
                "precision": "very-high",
                "cwe": [
                  {
                    "id": "CWE-89",
                    "name": "SQL Injection",
                    "category": "Injection",
                    "severity": "high"
                  },
                  {
                    "id": "CWE-90",
                    "name": "Unknown",
                    "category": "Unknown",
                    "severity": "unknown"
                  },
                  {
                    "id": "CWE-91",
